{
  "name": "labscan-server",
  "version": "0.1.0",
  "private": true,
  "description": "LabScan backend — ArUco/QR-driven lab experiment learning platform",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.658.1",
    "@aws-sdk/s3-request-presigner": "3.658.1",
    "bcryptjs": "2.4.3",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.21.1",
    "express-rate-limit": "7.4.1",
    "helmet": "8.0.0",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.0",
    "mysql2": "3.11.3",
    "uuid": "10.0.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "9.12.0",
    "eslint": "9.12.0",
    "globals": "15.11.0",
    "nodemon": "3.1.7",
    "supertest": "7.0.0",
    "vitest": "2.1.2"
  }
}
