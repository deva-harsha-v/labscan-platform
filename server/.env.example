# ---- Server ----
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed CORS origins (frontend URLs)
CORS_ORIGINS=http://localhost:5173

# ---- Database (MySQL) ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=labscan
DB_PASSWORD=labscan
DB_NAME=labscan
DB_CONNECTION_LIMIT=10

# ---- Auth ----
# Use long random strings in production (e.g. `openssl rand -hex 48`)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
BCRYPT_SALT_ROUNDS=12

# ---- Rate limiting ----
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10

# ---- Object storage (signed URLs for faculty-recorded / uploaded media) ----
# Any S3-compatible endpoint (AWS S3, Cloudflare R2, MinIO, etc.)
# Leave blank to disable signed-URL generation (endpoints return 503).
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=labscan-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
SIGNED_URL_TTL_SECONDS=3600

# ---- Seed (created by `npm run seed`) ----
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin12345
SEED_STUDENT_USERNAME=student
SEED_STUDENT_PASSWORD=student12345
